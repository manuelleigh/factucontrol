<%- include('partials/head') %>
<div class="app-shell">
  <%- include('partials/nav') %>
  <main class="app-main">
    <section class="hero-card">
      <div>
        <span class="eyebrow">Panel de inicio</span>
        <h2>Visibilidad inmediata del flujo de facturas</h2>
        <p>Controla lo gastado este mes, detecta pendientes y prioriza pagos antes del vencimiento.</p>
      </div>
      <div class="hero-actions">
        <a class="btn btn-light" href="/gastos">Registrar gasto</a>
        <a class="btn btn-outline-light" href="/compras">Registrar compra</a>
      </div>
    </section>

    <section class="kpi-grid">
      <article class="kpi-card">
        <span>Total del mes</span>
        <strong><%= helpers.formatCurrency(dashboard.resumen.totalMes) %></strong>
        <small>Gastos y compras registrados este mes.</small>
      </article>
      <article class="kpi-card">
        <span>Pendientes vigentes</span>
        <strong><%= dashboard.resumen.pendientesCantidad %></strong>
        <small><%= helpers.formatCurrency(dashboard.resumen.pendientesMonto) %> con vencimiento futuro.</small>
      </article>
      <article class="kpi-card warning">
        <span>Próximas a vencer</span>
        <strong><%= dashboard.resumen.proximasCantidad %></strong>
        <small><%= helpers.formatCurrency(dashboard.resumen.proximasMonto) %> en 7 días.</small>
      </article>
      <article class="kpi-card danger">
        <span>Vencidas</span>
        <strong><%= dashboard.resumen.vencidasCantidad %></strong>
        <small><%= helpers.formatCurrency(dashboard.resumen.vencidasMonto) %> atrasado.</small>
      </article>
    </section>

    <section class="kpi-grid">
      <article class="kpi-card">
        <span>Gastos operativos</span>
        <strong><%= helpers.formatCurrency(dashboard.moduleTotals.Gasto.total) %></strong>
        <small><%= dashboard.moduleTotals.Gasto.cantidad %> registros.</small>
      </article>
      <article class="kpi-card">
        <span>Compras de bienes</span>
        <strong><%= helpers.formatCurrency(dashboard.moduleTotals.Compra.total) %></strong>
        <small><%= dashboard.moduleTotals.Compra.cantidad %> registros.</small>
      </article>
      <article class="kpi-card">
        <span>Top proveedores</span>
        <strong><%= dashboard.topProviders.length %></strong>
        <small>Proveedores con mayor volumen registrado.</small>
      </article>
      <article class="kpi-card">
        <span>Registros recientes</span>
        <strong><%= dashboard.recentRecords.length %></strong>
        <small>Movimientos visibles en el panel.</small>
      </article>
    </section>

    <section class="content-grid">
      <article class="panel-card">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Distribución</span>
            <h3>Gasto por categoría</h3>
          </div>
        </div>
        <% if (dashboard.distribution.length) { %>
          <div class="progress-list">
            <% dashboard.distribution.forEach((item) => { %>
              <div class="progress-item">
                <div class="d-flex justify-content-between">
                  <strong><%= item.categoria %></strong>
                  <span><%= item.porcentaje %>%</span>
                </div>
                <div class="progress mt-2">
                  <div class="progress-bar" role="progressbar" style="width: <%= item.porcentaje %>%"></div>
                </div>
                <small><%= helpers.formatCurrency(item.total) %></small>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-state">Todavía no hay movimientos en el mes actual.</p>
        <% } %>
      </article>

      <article class="panel-card">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Actividad reciente</span>
            <h3>Últimos registros</h3>
          </div>
        </div>
        <% if (dashboard.recentRecords.length) { %>
          <div class="timeline-list">
            <% dashboard.recentRecords.forEach((record) => { %>
              <div class="timeline-item">
                <div class="status-dot <%= record.estadoEfectivo.toLowerCase() %>"></div>
                <div>
                  <strong><%= record.modulo %> - <%= record.numeroFactura %></strong>
                  <p><%= record.proveedor.nombre %> · <%= record.categoria %></p>
                </div>
                <div class="text-end">
                  <strong><%= helpers.formatCurrency(record.total) %></strong>
                  <p><%= helpers.formatDateReadable(record.fechaRegistro) %></p>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-state">Aún no se han registrado facturas.</p>
        <% } %>
      </article>
    </section>

    <section class="panel-card ai-panel">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Asistente IA</span>
          <h3>Análisis rápido con Groq</h3>
        </div>
        <button class="btn btn-primary" id="aiDashboardButton" type="button">Analizar ahora</button>
      </div>
      <p class="text-muted mb-3">
        Genera un resumen breve del estado financiero usando un modelo ligero y rápido, ideal para uso universitario.
      </p>
      <div class="ai-meta mb-3" id="aiDashboardMeta">Modelo sugerido: se seleccionará automáticamente según disponibilidad.</div>
      <div class="ai-result empty-state" id="aiDashboardResult">Pulsa "Analizar ahora" para obtener observaciones y acciones.</div>
    </section>

    <section class="content-grid">
      <article class="panel-card">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Top proveedores</span>
            <h3>Mayor volumen registrado</h3>
          </div>
        </div>
        <% if (dashboard.topProviders.length) { %>
          <div class="timeline-list">
            <% dashboard.topProviders.forEach((item) => { %>
              <div class="timeline-item">
                <div class="status-dot pendiente"></div>
                <div>
                  <strong><%= item.proveedor %></strong>
                  <p><%= item.cantidad %> registros</p>
                </div>
                <div class="text-end">
                  <strong><%= helpers.formatCurrency(item.total) %></strong>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-state">Todavía no hay proveedores con facturación registrada.</p>
        <% } %>
      </article>

      <article class="panel-card">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Reportes PDF</span>
            <h3>Generación de reportes</h3>
          </div>
        </div>
        <div class="report-grid">
          <form action="/api/reportes/mensual" method="get" target="_blank" class="report-card">
            <label class="form-label">Reporte mensual</label>
            <div class="row g-2">
              <div class="col-6"><input type="number" name="month" min="1" max="12" class="form-control" value="<%= new Date().getMonth() + 1 %>" /></div>
              <div class="col-6"><input type="number" name="year" min="2020" class="form-control" value="<%= new Date().getFullYear() %>" /></div>
            </div>
            <button class="btn btn-primary mt-3">Generar PDF</button>
          </form>
          <form action="/api/reportes/categorias" method="get" target="_blank" class="report-card">
            <label class="form-label">Resumen por categoría</label>
            <div class="row g-2">
              <div class="col-6"><input type="date" name="startDate" class="form-control" /></div>
              <div class="col-6"><input type="date" name="endDate" class="form-control" /></div>
            </div>
            <button class="btn btn-outline-primary mt-3">Generar PDF</button>
          </form>
        </div>
      </article>
    </section>
  </main>
</div>
<script src="/js/dashboard-ai.js"></script>
<%- include('partials/footer') %>
