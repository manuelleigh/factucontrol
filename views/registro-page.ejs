<div class="app-shell">
  <%- include('partials/nav') %>
  <main class="app-main">
    <section class="page-header">
      <div>
        <span class="eyebrow">Gestión documental</span>
        <h2><%= sectionTitle %></h2>
        <p>Registra facturas válidas, adjunta el soporte y controla el estado de pago en un solo flujo.</p>
      </div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#registroModal">Nueva factura</button>
    </section>

    <section class="panel-card">
      <form class="row g-3 align-items-end" method="get">
        <div class="col-md-3">
          <label class="form-label">Buscar</label>
          <input class="form-control" type="text" name="search" value="<%= filters.search %>" placeholder="Factura, concepto o bien" />
        </div>
        <div class="col-md-3">
          <label class="form-label">Proveedor</label>
          <select name="proveedorId" class="form-select">
            <option value="">Todos</option>
            <% proveedores.forEach((proveedor) => { %>
              <option value="<%= proveedor.id %>" <%= filters.proveedorId == proveedor.id ? 'selected' : '' %>><%= proveedor.nombre %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Estado</label>
          <select name="estado" class="form-select">
            <option value="">Todos</option>
            <% estadosRegistro.forEach((estado) => { %>
              <option value="<%= estado %>" <%= filters.estado === estado ? 'selected' : '' %>><%= estado %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Categoría</label>
          <select name="categoria" class="form-select">
            <option value="">Todas</option>
            <% categories.forEach((categoria) => { %>
              <option value="<%= categoria %>" <%= filters.categoria === categoria ? 'selected' : '' %>><%= categoria %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2"><label class="form-label">Desde</label><input type="date" name="fechaInicio" class="form-control" value="<%= filters.fechaInicio %>" /></div>
        <div class="col-md-2"><label class="form-label">Hasta</label><input type="date" name="fechaFin" class="form-control" value="<%= filters.fechaFin %>" /></div>
        <div class="col-md-3"><button class="btn btn-outline-primary w-100">Aplicar filtros</button></div>
        <div class="col-md-3"><a href="/<%= pageType === 'compra' ? 'compras' : 'gastos' %>" class="btn btn-light w-100">Limpiar</a></div>
      </form>
    </section>

    <section class="panel-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">Mostrando <%= records.length %> registros</small>
        <small class="text-muted">Página <%= pagination.page %> de <%= pagination.totalPages %></small>
      </div>
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Factura</th>
              <th>Proveedor</th>
              <th>Fechas</th>
              <th>Total</th>
              <th>Estado</th>
              <th>Adjunto</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (records.length) { %>
              <% records.forEach((record) => { %>
                <tr>
                  <td><strong><%= record.numeroFactura %></strong><div class="text-muted small"><%= record.categoria %></div></td>
                  <td>
                    <strong><%= record.proveedor.nombre %></strong>
                    <div class="text-muted small"><%= record.concepto %></div>
                    <% if (pageType === 'compra') { %><div class="text-muted small"><%= record.nombreBien %> · <%= record.cantidad %> und. · <%= record.estadoBien %></div><% } %>
                  </td>
                  <td><div><%= helpers.formatDateReadable(record.fechaEmision) %></div><div class="text-muted small">Vence <%= helpers.formatDateReadable(record.fechaVencimiento) %></div></td>
                  <td><strong><%= helpers.formatCurrency(record.total) %></strong></td>
                  <td><span class="status-badge <%= record.estadoEfectivo.toLowerCase() %>"><%= record.estadoEfectivo %></span></td>
                  <td><% if (record.archivoAdjunto) { %><a href="<%= record.archivoAdjunto %>" target="_blank" class="btn btn-sm btn-light">Ver archivo</a><% } else { %><span class="text-muted small">Sin adjunto</span><% } %></td>
                  <td class="text-end">
                    <button class="btn btn-sm btn-light js-edit-registro" data-registro='<%- JSON.stringify(record) %>' data-bs-toggle="modal" data-bs-target="#registroModal">Editar</button>
                    <% if (record.estadoEfectivo !== 'Pagada') { %><button class="btn btn-sm btn-outline-success js-pay-registro" data-id="<%= record.id %>" data-numero="<%= record.numeroFactura %>" data-bs-toggle="modal" data-bs-target="#pagoModal">Marcar pagada</button><% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="7" class="text-center py-5 text-muted">No hay registros para los filtros seleccionados.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <% if (pagination.totalPages > 1) { %>
        <nav class="mt-4">
          <ul class="pagination justify-content-center mb-0">
            <li class="page-item <%= pagination.hasPrev ? '' : 'disabled' %>">
              <a class="page-link" href="?search=<%= encodeURIComponent(filters.search) %>&proveedorId=<%= filters.proveedorId %>&estado=<%= filters.estado %>&categoria=<%= filters.categoria %>&fechaInicio=<%= filters.fechaInicio %>&fechaFin=<%= filters.fechaFin %>&page=<%= pagination.page - 1 %>&pageSize=<%= pagination.pageSize %>">Anterior</a>
            </li>
            <li class="page-item disabled"><span class="page-link">Página <%= pagination.page %> de <%= pagination.totalPages %></span></li>
            <li class="page-item <%= pagination.hasNext ? '' : 'disabled' %>">
              <a class="page-link" href="?search=<%= encodeURIComponent(filters.search) %>&proveedorId=<%= filters.proveedorId %>&estado=<%= filters.estado %>&categoria=<%= filters.categoria %>&fechaInicio=<%= filters.fechaInicio %>&fechaFin=<%= filters.fechaFin %>&page=<%= pagination.page + 1 %>&pageSize=<%= pagination.pageSize %>">Siguiente</a>
            </li>
          </ul>
        </nav>
      <% } %>
    </section>
  </main>
</div>

<div class="modal fade" id="registroModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <div><span class="eyebrow">Formulario principal</span><h5 class="modal-title">Factura de <%= singular %></h5></div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="registroForm" class="modal-body row g-3" enctype="multipart/form-data" data-type="<%= pageType %>">
        <input type="hidden" name="id" />
        <div class="col-12 d-none" id="registroErrors"></div>
        <div class="col-md-4"><label class="form-label">Proveedor</label><select name="proveedorId" class="form-select" required><option value="">Selecciona un proveedor</option><% proveedores.forEach((proveedor) => { %><option value="<%= proveedor.id %>"><%= proveedor.nombre %></option><% }) %></select></div>
        <div class="col-md-4"><label class="form-label">Número de factura</label><input class="form-control" name="numeroFactura" required /></div>
        <div class="col-md-4"><label class="form-label">Categoría</label><select name="categoria" class="form-select" required><option value="">Selecciona una categoría</option><% categories.forEach((categoria) => { %><option value="<%= categoria %>"><%= categoria %></option><% }) %></select></div>
        <div class="col-md-3"><label class="form-label">Fecha de emisión</label><input type="date" class="form-control" name="fechaEmision" required /></div>
        <div class="col-md-3"><label class="form-label">Fecha de vencimiento</label><input type="date" class="form-control" name="fechaVencimiento" required /></div>
        <div class="col-md-3"><label class="form-label">Base imponible</label><input type="number" min="0" step="0.01" class="form-control js-base-imponible" name="baseImponible" required /></div>
        <div class="col-md-3"><label class="form-label">IVA (%)</label><input type="number" min="0" step="0.01" class="form-control js-impuesto" name="porcentajeImpuesto" value="0" /></div>
        <div class="col-12"><label class="form-label">Concepto</label><textarea class="form-control" name="concepto" rows="2" required></textarea></div>
        <% if (pageType === 'compra') { %>
          <div class="col-md-6"><label class="form-label">Nombre del bien</label><input class="form-control" name="nombreBien" /></div>
          <div class="col-md-3"><label class="form-label">Cantidad</label><input type="number" min="1" class="form-control" name="cantidad" value="1" /></div>
          <div class="col-md-3"><label class="form-label">Estado del bien</label><select class="form-select" name="estadoBien"><option value="">Selecciona</option><% estadosBien.forEach((estado) => { %><option value="<%= estado %>"><%= estado %></option><% }) %></select></div>
        <% } %>
        <div class="col-md-6"><label class="form-label">Archivo adjunto</label><input class="form-control" type="file" name="archivoAdjunto" accept=".pdf,image/*" /></div>
        <div class="col-md-6"><label class="form-label">Total calculado</label><div class="total-preview" id="totalPreview">S/ 0.00</div></div>
      </form>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" form="registroForm" class="btn btn-primary">Revisar y guardar</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="pagoModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <div><span class="eyebrow">Cambio de estado</span><h5 class="modal-title">Registrar pago</h5></div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="pagoForm" class="modal-body">
        <input type="hidden" name="id" />
        <div class="d-none" id="pagoErrors"></div>
        <p class="text-muted">Actualizarás la factura <strong id="pagoFacturaNumero">-</strong> a estado pagada.</p>
        <div class="mb-3"><label class="form-label">Fecha de pago</label><input type="date" class="form-control" name="fechaPago" required /></div>
        <div class="mb-3"><label class="form-label">Método de pago</label><select name="metodoPago" class="form-select" required><option value="">Selecciona</option><% metodosPago.forEach((metodo) => { %><option value="<%= metodo %>"><%= metodo %></option><% }) %></select></div>
      </form>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" form="pagoForm" class="btn btn-success">Guardar pago</button>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <div><span class="eyebrow">Confirmación</span><h5 class="modal-title">Revisa la factura antes de guardar</h5></div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="confirmation-grid" id="confirmSummary"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Volver a editar</button>
        <button type="button" class="btn btn-primary" id="confirmSaveButton">Confirmar guardado</button>
      </div>
    </div>
  </div>
</div>
<script src="/js/registros.js"></script>
