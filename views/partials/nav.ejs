<aside class="app-sidebar">
  <div>
    <div class="sidebar-brand">
      <span class="brand-mark">FC</span>
      <div>
        <h1>FactuControl</h1>
        <p>Gestión de facturas y proveedores</p>
      </div>
    </div>
    <% if (currentUser) { %>
      <div class="sidebar-user mt-3">
        <strong><%= currentUser.name %></strong>
        <div class="text-muted small"><%= currentUser.email %></div>
        <span class="status-badge pendiente mt-2 d-inline-flex"><%= currentUser.role %></span>
      </div>
    <% } %>
    <nav class="nav flex-column gap-2 mt-4">
      <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Panel</a>
      <a class="nav-link <%= currentPath === '/proveedores' ? 'active' : '' %>" href="/proveedores">Proveedores</a>
      <a class="nav-link <%= currentPath === '/gastos' ? 'active' : '' %>" href="/gastos">Gastos</a>
      <a class="nav-link <%= currentPath === '/compras' ? 'active' : '' %>" href="/compras">Compras</a>
    </nav>
  </div>
  <% if (currentUser) { %>
    <form action="/logout" method="post" class="mt-4">
      <button class="btn btn-outline-light w-100" type="submit">Cerrar sesión</button>
    </form>
  <% } %>
</aside>
